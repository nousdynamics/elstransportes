{
  // Cloudflare Workers — Static Assets (assets-only Worker, sem script)
  // Docs: https://developers.cloudflare.com/workers/static-assets/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "elstransportes",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./public",
    // unknown paths retornam 404 real (bom p/ SEO; sem soft-404 de SPA)
    "not_found_handling": "404-page"
  }
}
